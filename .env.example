# Database Configuration
DATABASE_SERVER=fabric-server.database.windows.net
DATABASE_NAME=fabricdb
DATABASE_USER=fabricadmin
DATABASE_PASSWORD=your-database-password

# Anthropic Claude Configuration
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-openai.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-5-chat

# Azure AI Foundry Project
AZURE_AI_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com/api/projects/yourproject
BING_GROUNDING_CONNECTION_ID=/subscriptions/your-subscription-id/resourceGroups/your-rg/providers/Microsoft.CognitiveServices/accounts/your-account/projects/your-project/connections/your-connection

# Legacy Bing Search
BING_SEARCH_API_KEY=your-bing-search-key

# Microsoft Fabric Configuration
FABRIC_CLIENT_ID=your-fabric-client-id
FABRIC_TENANT_ID=your-tenant-id
FABRIC_CLIENT_SECRET=your-fabric-client-secret

# Workspace Backend Integration
WORKSPACE_BACKEND_URL=https://fabricbackend.lemonfield-12c57489.eastus.azurecontainerapps.io

# Development Mode (set to false for production)
DISABLE_AUTH=true

# Azure Storage Account Configuration
STORAGE_ACCOUNT_NAME=your-storage-account-name
STORAGE_ACCOUNT_KEY=your-storage-account-key
