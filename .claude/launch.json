{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "port": 3002,
      "autoPort": true,
      "cwd": "frontend",
      "env": {
        "PORT": "3002",
        "DISABLE_ESLINT_PLUGIN": "true"
      }
    },
    {
      "name": "backend",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["main.py"],
      "port": 8080,
      "cwd": "backend"
    }
  ]
}
